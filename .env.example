# Backend (in-docker hostnames)
KERIA_URL=http://keria:3901
KERIA_BOOT_URL=http://keria:3903
ISSUER_NAME=keri-demo-issuer
ISSUER_REGISTRY=keri-demo-registry
# 21-char salt; leave blank to auto-generate & persist to backend/data/issuer.salt
ISSUER_SALT=
# Schema host reachable by THIS stack's KERIA (issuer bootstrap + demo holder).
SCHEMA_RESOLVE_HOST=http://app:3001
# Embedded oobiUrl base + issuer loc-scheme. Resolved by the wallet's KERIA
# agent — in the standard setup that IS this stack's keria container (the
# Veridian app just connects to it via localhost:3901), so keep the docker
# service name. Only change if the wallet uses a different KERIA elsewhere.
SCHEMA_OOBI_HOST=http://app:3001
PORT=3001

# Frontend dev fallbacks (runtime values come from /api/config)
VITE_KERIA_URL=http://localhost:3901
VITE_KERIA_BOOT_URL=http://localhost:3903
VITE_API_BASE=
